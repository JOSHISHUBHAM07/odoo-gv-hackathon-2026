generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Role-Based Access Control (RBAC) - Page 1 [cite: 12]
enum Role {
  ADMIN
  FLEET_MANAGER
  DISPATCHER
  SAFETY_OFFICER
  FINANCE_ANALYST
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(DISPATCHER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Asset Management Status - Page 3 [cite: 24, 32]
enum VehicleStatus {
  AVAILABLE
  ON_TRIP
  IN_SHOP
  RETIRED
}

enum FuelType {
  DIESEL
  PETROL
  EV
  HYBRID
}

model Vehicle {
  id                 String           @id @default(cuid())
  model              String
  licensePlate       String           @unique // Unique ID [cite: 23]
  acquisitionCost    Float // Needed for ROI 
  capacityKg         Float // Max Load Capacity [cite: 23]
  odometerKm         Float            @default(0)
  insuranceExpiry    DateTime
  registrationExpiry DateTime
  fuelType           FuelType
  status             VehicleStatus    @default(AVAILABLE)
  trips              Trip[]
  maintenanceLogs    MaintenanceLog[]
  fuelLogs           FuelLog[]
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
}

// Driver Performance & Compliance - Page 7 [cite: 37, 39, 41]
enum DriverStatus {
  ON_DUTY
  OFF_DUTY
  SUSPENDED
  ON_TRIP
}

model Driver {
  id                 String       @id @default(cuid())
  name               String
  licenseNumber      String       @unique
  licenseExpiry      DateTime // Blocks assignment if expired [cite: 39]
  licenseCategory    String // e.g., "Van", "Truck" [cite: 49]
  status             DriverStatus @default(ON_DUTY)
  contactInfo        String
  safetyScore        Float        @default(100.0) // Page 7 
  tripCompletionRate Float        @default(0.0) // Page 7 
  trips              Trip[]
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
}

// Trip Workflow - Page 4 [cite: 25, 29]
enum TripStatus {
  DRAFT
  DISPATCHED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model Trip {
  id                   String     @id @default(cuid())
  origin               String
  destination          String
  distanceKm           Float
  cargoWeightKg        Float // Validation: Weight < Capacity [cite: 28]
  revenue              Float // Needed for ROI 
  expectedDeliveryTime DateTime
  finalOdometer        Float? // Entered during Completion 
  status               TripStatus @default(DRAFT)
  vehicleId            String
  vehicle              Vehicle    @relation(fields: [vehicleId], references: [id])
  driverId             String
  driver               Driver     @relation(fields: [driverId], references: [id])
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt
}

// Maintenance Health Tracking - Page 5 [cite: 30, 31]
enum ServiceType {
  PREVENTIVE
  BREAKDOWN
  EMERGENCY
}

model MaintenanceLog {
  id             String      @id @default(cuid())
  serviceType    ServiceType
  description    String? // Specific health tracking 
  cost           Float
  serviceDate    DateTime    @default(now())
  nextServiceDue DateTime // Changed to DateTime for scheduling [cite: 5]
  vendorName     String
  vehicleId      String
  vehicle        Vehicle     @relation(fields: [vehicleId], references: [id])
  createdAt      DateTime    @default(now())
}

// Financial Performance - Page 6 [cite: 33, 36]
model FuelLog {
  id         String   @id @default(cuid())
  fuelLiters Float
  cost       Float
  date       DateTime @default(now())
  vehicleId  String
  vehicle    Vehicle  @relation(fields: [vehicleId], references: [id])
  createdAt  DateTime @default(now())
}

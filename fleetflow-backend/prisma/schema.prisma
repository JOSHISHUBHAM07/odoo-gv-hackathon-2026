generator client {
  provider      = "prisma-client-js"
  // native: for your local Windows machine
  // rhel-openssl-3.0.x: for Vercel's serverless environment
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Rest of your schema remains exactly as you wrote it ---

// Role-Based Access Control (RBAC) - Page 1
enum Role {
  ADMIN
  FLEET_MANAGER
  DISPATCHER
  SAFETY_OFFICER
  FINANCE_ANALYST
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String   
  name      String
  role      Role     @default(DISPATCHER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Asset Management Status - Page 3
enum VehicleStatus {
  AVAILABLE
  ON_TRIP
  IN_SHOP
  RETIRED
}

enum FuelType {
  DIESEL
  PETROL
  EV
  HYBRID
}

model Vehicle {
  id                 String           @id @default(cuid())
  model              String
  licensePlate       String           @unique
  acquisitionCost    Float            
  capacityKg         Float            
  odometerKm         Float            @default(0)
  insuranceExpiry    DateTime
  registrationExpiry DateTime
  fuelType           FuelType
  status             VehicleStatus    @default(AVAILABLE)
  trips              Trip[]
  maintenanceLogs    MaintenanceLog[]
  fuelLogs           FuelLog[]
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
}

// Driver Performance & Compliance - Page 7
enum DriverStatus {
  ON_DUTY
  OFF_DUTY
  SUSPENDED
  ON_TRIP
}

model Driver {
  id                 String       @id @default(cuid())
  name               String
  licenseNumber      String       @unique
  licenseExpiry      DateTime     
  licenseCategory    String       
  status             DriverStatus @default(ON_DUTY)
  contactInfo        String
  safetyScore        Float        @default(100.0) 
  tripCompletionRate Float        @default(0.0)   
  trips              Trip[]
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
}

// Trip Workflow - Page 4
enum TripStatus {
  DRAFT
  DISPATCHED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model Trip {
  id                   String     @id @default(cuid())
  origin               String
  destination          String
  distanceKm           Float
  cargoWeightKg        Float      
  revenue              Float      
  expectedDeliveryTime DateTime
  finalOdometer        Float?     
  status               TripStatus @default(DRAFT)
  vehicleId            String
  vehicle              Vehicle    @relation(fields: [vehicleId], references: [id])
  driverId             String
  driver               Driver     @relation(fields: [driverId], references: [id])
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt
}

// Maintenance Health Tracking - Page 5
enum ServiceType {
  PREVENTIVE
  BREAKDOWN
  EMERGENCY
}

model MaintenanceLog {
  id             String      @id @default(cuid())
  serviceType    ServiceType
  description    String?     
  cost           Float
  serviceDate    DateTime    @default(now())
  nextServiceDue DateTime    
  vendorName     String
  vehicleId      String
  vehicle        Vehicle     @relation(fields: [vehicleId], references: [id])
  createdAt      DateTime    @default(now())
}

// Financial Performance - Page 6
model FuelLog {
  id          String   @id @default(cuid())
  fuelLiters  Float
  cost        Float
  date        DateTime @default(now())
  vehicleId   String
  vehicle     Vehicle  @relation(fields: [vehicleId], references: [id])
  createdAt   DateTime @default(now())
}